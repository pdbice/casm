package main

Token_Kind :: enum {
	Definition,
	Instruction_Start,
		CLS,
		RET,
		JMP,
		CALL,
		SE,
		SNE,
		MOV,
		ADD,
		OR,
		AND,
		XOR,
		SUB,
		SHR,
		SUBN,
		SHL,
		LDA,
		RAND,
		DRW,
		SKP,
		SKNP,
		LDF,
		BCD,
		STR,
		LDR,
	Instruction_End,
	Directive_Start,
		BYTE,
		ASCII,
	Directive_End,
	Label,
	UInt,
	String,
	EOL,
	EOF,
}

Token :: struct {
	text:        string,
	kind:        Token_Kind,
	line_number: int,
}
